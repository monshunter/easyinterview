# easyinterview .env.example — secrets-and-config spec §3.1.1.
#
# Layer 2/3 of the D-1 priority stack: env vars override config/{APP_ENV}.yaml
# but lose to runtime secrets injected through SecretSource. Keep this file
# in lockstep with the spec table — `make lint-config` fails if any key is
# missing on either side. Real credentials MUST NOT be committed; values
# below are example values or local-only defaults.
#
# Format: <KEY>=<value>  # Owner subspec; prod required: yes/no/conditional

# --- Runtime ---------------------------------------------------------------
APP_ENV=dev                                           # Owner: A4; prod required: yes
APP_LISTEN_ADDR=:10901                                # Owner: A4; prod required: yes

# --- Storage / cache -------------------------------------------------------
DATABASE_URL=postgres://easyinterview:dev@localhost:5432/easyinterview?sslmode=disable  # Owner: A4 (A2 dev default); prod required: yes
REDIS_URL=redis://localhost:6379/0                    # Owner: A4; prod required: yes
OBJECT_STORAGE_ENDPOINT=http://localhost:9000         # Owner: A4; prod required: yes
OBJECT_STORAGE_BUCKET=easyinterview-dev               # Owner: A4; prod required: yes
OBJECT_STORAGE_ACCESS_KEY=                            # secret; populate via runtime secret in prod. Owner: A4; prod required: yes
OBJECT_STORAGE_SECRET_KEY=                            # secret; populate via runtime secret in prod. Owner: A4; prod required: yes

# --- Observability ---------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=                          # Owner: A4 + F1; prod required: conditional (set when OTel collector available)
LOG_LEVEL=info                                        # Owner: A4; prod required: yes

# --- Auth (C1 / ADR-Q1) ----------------------------------------------------
SESSION_COOKIE_SECRET=                                # secret; signs ei_session cookie. Owner: A4 + C1; prod required: yes (dev init-generated)
AUTH_CHALLENGE_TOKEN_PEPPER=                          # secret; magic-link challenge pepper. Owner: A4 + C1; prod required: yes (dev init-generated)

# --- AI provider (A3) -------------------------------------------------------
AI_PROVIDER_REGISTRY_PATH=config/ai-providers.yaml     # Owner: A4 + A3; prod required: yes
AI_PROVIDER_BASE_URL=https://api.deepseek.com          # Owner: A4 + A3; prod required: conditional (when selected provider ref uses this env)
AI_PROVIDER_API_KEY=                                   # secret. Owner: A4 + A3; prod required: conditional (when selected provider ref uses this env)
AI_MODEL_PROFILE_PATH=config/ai-profiles.yaml         # Owner: A4 + A3; prod required: yes
AI_DEBUG_CAPTURE_RAW_IO=true                          # Owner: A4 + A3; prod required: no (dev/test only; staging/prod reject true)
AI_DEBUG_RAW_IO_PATH=.test-output/local-dev/ai-raw.ndjson # Owner: A4 + A3; prod required: no (sensitive local-only Complete request/response evidence)
DOUBAO_SPEECH_BASE_URL=https://api.volcengine.com      # Owner: A4 + A3; prod required: conditional (when doubao_speech provider is selected)
DOUBAO_SPEECH_API_KEY=                                  # secret. Owner: A4 + A3; prod required: conditional
MINIMAX_SPEECH_BASE_URL=https://api.minimax.chat        # Owner: A4 + A3; prod required: conditional (when minimax_speech provider is selected)
MINIMAX_SPEECH_API_KEY=                                 # secret. Owner: A4 + A3; prod required: conditional

# --- Feature flags (F2) ----------------------------------------------------
FEATURE_FLAG_SOURCE=file                              # `file` or `posthog`. Owner: A4; prod required: yes
FEATURE_FLAG_FILE_PATH=config/feature-flags.yaml      # Owner: A4; prod required: conditional (when FEATURE_FLAG_SOURCE=file)
POSTHOG_HOST=                                         # Owner: A4 + F2; prod required: conditional (when FEATURE_FLAG_SOURCE=posthog)
POSTHOG_SELF_HOSTED=false                             # Owner: A4 + F2; prod required: conditional (must be true in staging/prod when posthog)
POSTHOG_PROJECT_API_KEY=                              # secret. Owner: A4 + F2; prod required: conditional (when posthog)
POSTHOG_PUBLIC_KEY=                                   # public; emitted to frontend only when analyticsEnabled. Owner: A4 + F2; prod required: conditional

# --- Email (C1) ------------------------------------------------------------
EMAIL_PROVIDER=mailpit                                # Owner: A4 + C1; prod required: yes
EMAIL_SMTP_HOST=127.0.0.1                             # Owner: A4 + C1; prod required: conditional (mailpit or smtp)
EMAIL_SMTP_PORT=1025                                  # Owner: A4 + C1; prod required: conditional (mailpit or smtp)
EMAIL_SMTP_USERNAME=                                  # Owner: A4 + C1; prod required: conditional (smtp)
EMAIL_SMTP_PASSWORD=                                  # secret. Owner: A4 + C1; prod required: conditional (smtp)
EMAIL_SMTP_TLS_MODE=none                              # Owner: A4 + C1; prod required: conditional (smtp: starttls or tls)
EMAIL_FROM_ADDRESS=noreply@easyinterview.local        # Owner: A4 + C1; prod required: yes
EMAIL_VERIFY_BASE_URL=http://127.0.0.1:10900/auth/verify # Owner: A4 + C1; prod required: yes
