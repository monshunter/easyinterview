import type * as Types from "./types";

// Thin operationId-keyed fetch client for easyinterview API v1.0.0.
//
// The client only handles HTTP plumbing (method + path + JSON body).
// Authentication is delegated to the same-origin first-party session cookie
// per ADR-Q1; the consumer must use `credentials: "include"` (the default for
// same-origin requests). Request/response shapes are imported from
// `./types.ts` so any drift in openapi.yaml propagates here automatically.

export interface ClientOptions {
	/** Base URL prefix; defaults to `/api/v1`. */
	baseUrl?: string;
	/** Optional fetch override (e.g., for tests). */
	fetch?: typeof fetch;
	/** Optional default headers (X-Client-Version, Accept-Language). */
	headers?: Record<string, string>;
}

export interface RequestOptions {
	signal?: AbortSignal;
	idempotencyKey?: string;
	headers?: Record<string, string>;
	query?: Record<string, string | number | boolean | undefined>;
}

export type ApiClientErrorKind = "http" | "abort" | "transport";

export class ApiClientError extends Error {
	readonly kind: ApiClientErrorKind;
	readonly status: number | null;
	readonly apiError: Types.ApiErrorResponse | null;

	constructor(
		kind: ApiClientErrorKind,
		status: number | null,
		apiError: Types.ApiErrorResponse | null,
		cause?: unknown,
	) {
		const transportDetail = kind === "transport" && cause instanceof Error
			? `: ${cause.message}`
			: "";
		const message = kind === "http"
			? `HTTP ${status ?? "unknown"}${apiError ? ` ${apiError.error.code}` : ""}`
			: kind === "abort"
				? "Request aborted"
				: `Request transport failed${transportDetail}`;
		super(message, cause === undefined ? undefined : { cause });
		this.name = "ApiClientError";
		this.kind = kind;
		this.status = status;
		this.apiError = apiError;
	}
}

const DEFAULT_BASE_URL = "/api/v1";

function buildQuery(params?: Record<string, string | number | boolean | undefined>): string {
	if (!params) return "";
	const search = new URLSearchParams();
	for (const key of Object.keys(params).sort()) {
		const value = params[key];
		if (value === undefined) continue;
		search.append(key, String(value));
	}
	const qs = search.toString();
	return qs ? `?${qs}` : "";
}

function buildPath(template: string, params: Record<string, string>): string {
	return template.replace(/\{([^}]+)\}/g, (_, name) => {
		const value = params[name];
		if (value === undefined) {
			throw new Error(`missing path parameter: ${name}`);
		}
		return encodeURIComponent(value);
	});
}

function isRecord(value: unknown): value is Record<string, unknown> {
	return typeof value === "object" && value !== null && !Array.isArray(value);
}

function parseApiErrorResponse(text: string): Types.ApiErrorResponse | null {
	if (text.trim() === "") return null;
	let parsed: unknown;
	try {
		parsed = JSON.parse(text);
	} catch {
		return null;
	}
	if (!isRecord(parsed) || !isRecord(parsed.error)) return null;
	const error = parsed.error;
	if (
		typeof error.code !== "string"
		|| typeof error.message !== "string"
		|| typeof error.requestId !== "string"
		|| typeof error.retryable !== "boolean"
		|| (error.details !== undefined && !isRecord(error.details))
	) {
		return null;
	}
	return {
		error: {
			code: error.code,
			message: error.message,
			requestId: error.requestId,
			retryable: error.retryable,
			...(error.details === undefined ? {} : { details: error.details }),
		},
	};
}

function isAbortError(cause: unknown): boolean {
	return isRecord(cause) && cause.name === "AbortError";
}

function requestFailure(cause: unknown): ApiClientError {
	return new ApiClientError(
		isAbortError(cause) ? "abort" : "transport",
		null,
		null,
		cause,
	);
}

function canonicalHeaders(headers: Record<string, string>): readonly (readonly [string, string])[] {
	return Array.from(new Headers(headers).entries())
		.map(([key, value]) => [key.toLowerCase(), value] as const)
		.sort(([left], [right]) => left.localeCompare(right));
}

function canonicalStatuses(statuses: readonly number[]): readonly number[] {
	return Array.from(new Set(statuses)).sort((left, right) => left - right);
}

const VERIFY_AUTH_PATH = "/auth/email/verify";

export class EasyInterviewClient {
	readonly baseUrl: string;
	readonly fetchFn: typeof fetch;
	readonly defaultHeaders: Record<string, string>;
	private readonly inFlightReads = new Map<string, Promise<unknown>>();
	private readEpoch = 0;
	private authEpoch = 0;

	constructor(options: ClientOptions = {}) {
		this.baseUrl = options.baseUrl ?? DEFAULT_BASE_URL;
		this.fetchFn = options.fetch ?? globalThis.fetch.bind(globalThis);
		this.defaultHeaders = { ...(options.headers ?? {}) };
	}

	private request<T>(method: string, path: string, body: unknown, opts?: RequestOptions, okStatuses: readonly number[] = []): Promise<T> {
		const normalizedMethod = method.toUpperCase();
		const headers: Record<string, string> = {
			"Accept": "application/json",
			...this.defaultHeaders,
			...(opts?.headers ?? {}),
		};
		if (body !== undefined) headers["Content-Type"] = "application/json";
		if (opts?.idempotencyKey) headers["Idempotency-Key"] = opts.idempotencyKey;
		const url = `${this.baseUrl}${path}${buildQuery(opts?.query)}`;
		const isVerifyMutation = normalizedMethod === "GET" && path === VERIFY_AUTH_PATH;
		const isMutation = normalizedMethod !== "GET" || isVerifyMutation;

		if (isMutation) {
			this.readEpoch += 1;
			const mutation = this.performRequest<T>(normalizedMethod, url, body, headers, opts, okStatuses);
			return mutation.then(
				(value) => {
					this.readEpoch += 1;
					if (isVerifyMutation) this.authEpoch += 1;
					return value;
				},
				(error: unknown) => {
					this.readEpoch += 1;
					throw error;
				},
			);
		}

		if (opts?.signal) {
			return this.performRequest<T>(normalizedMethod, url, body, headers, opts, okStatuses);
		}

		const key = JSON.stringify([
			normalizedMethod,
			url,
			canonicalHeaders(headers),
			canonicalStatuses(okStatuses),
			this.readEpoch,
			this.authEpoch,
		]);
		const existing = this.inFlightReads.get(key);
		if (existing) return existing as Promise<T>;

		const request = this.performRequest<T>(normalizedMethod, url, body, headers, opts, okStatuses);
		this.inFlightReads.set(key, request);
		const cleanup = () => {
			if (this.inFlightReads.get(key) === request) this.inFlightReads.delete(key);
		};
		void request.then(cleanup, cleanup);
		return request;
	}

	private async performRequest<T>(method: string, url: string, body: unknown, headers: Record<string, string>, opts?: RequestOptions, okStatuses: readonly number[] = []): Promise<T> {
		let response: Response;
		try {
			response = await this.fetchFn(url, {
				method,
				headers,
				body: body === undefined ? undefined : JSON.stringify(body),
				credentials: "include",
				signal: opts?.signal,
			});
		} catch (cause) {
			throw requestFailure(cause);
		}
		let text: string;
		try {
			text = await response.text();
		} catch (cause) {
			throw requestFailure(cause);
		}
		if (!response.ok && !okStatuses.includes(response.status)) {
			const apiError = parseApiErrorResponse(text);
			throw new ApiClientError("http", response.status, apiError);
		}
		if (response.status === 204 || text.trim() === "") {
			return undefined as T;
		}
		return JSON.parse(text) as T;
	}

{{range .Operations}}
	/** {{.OperationID}} — {{.Method}} {{.Path}}{{if .Summary}}: {{.Summary}}{{end}} */
	async {{.OperationID}}({{.TSMethodSignature}}): Promise<{{.TSReturnType}}> {
		return this.request<{{.TSReturnType}}>(
			"{{.MethodUpper}}",
			{{.TSPathExpression}},
			{{.TSBodyArg}},
			{{.TSOptsArg}}{{if .TSNonOKStatusArg}},
			{{.TSNonOKStatusArg}}{{end}},
		);
	}
{{end}}
}

export const ALL_OPERATION_IDS = [
{{- range .Operations}}
	"{{.OperationID}}",
{{- end}}
] as const;

export type OperationId = (typeof ALL_OPERATION_IDS)[number];

export interface Route {
	operationId: OperationId;
	method: string;
	path: string;
}

export const ALL_ROUTES = [
{{- range .Operations}}
	{ operationId: "{{.OperationID}}", method: "{{.MethodUpper}}", path: "{{.Path}}" },
{{- end}}
] as const satisfies readonly Route[];
