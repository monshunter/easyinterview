    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "answerCharLength": {
          "type": "integer"
        },
        "followUpCount": {
          "type": "integer"
        },
        "questionIntent": {
          "type": "string"
        },
        "sessionId": {
