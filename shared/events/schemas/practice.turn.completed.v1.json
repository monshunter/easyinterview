        "followUpCount",
        "questionIntent",
        "sessionId",
        "turnId",
        "turnIndex"
      ],
      "type": "object"
    },
    "producer": {
      "enum": [
        "api"
      ]
    },
    "traceId": {
      "type": "string"
    }
  },
  "required": [
    "eventId",
    "eventName",
    "eventVersion",
    "aggregateType",
    "aggregateId",
    "occurredAt",
    "producer",
    "payload"
