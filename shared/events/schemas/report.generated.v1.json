{
  "$id": "shared/events/schemas/report.generated.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "aggregateId": {
      "format": "uuid",
      "type": "string"
    },
    "aggregateType": {
      "const": "feedback_report"
    },
    "eventId": {
      "format": "uuid",
      "type": "string"
    },
    "eventName": {
      "const": "report.generated"
    },
    "eventVersion": {
      "const": 1
    },
    "occurredAt": {
      "format": "date-time",
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "modelId": {
          "type": "string"
        },
        "preparednessLevel": {
          "$ref": "../refs/ReadinessTier.json"
        },
        "promptVersion": {
          "type": "string"
        },
        "questionIssueCount": {
          "type": "integer"
        },
        "reportId": {
          "type": "string"
        },
        "rubricVersion": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "targetJobId": {
          "type": "string"
        }
      },
      "required": [
        "modelId",
        "preparednessLevel",
        "promptVersion",
        "questionIssueCount",
        "reportId",
        "rubricVersion",
        "sessionId",
        "targetJobId"
      ],
      "type": "object"
    },
    "producer": {
      "enum": [
        "backend_async"
      ]
    },
    "traceId": {
      "type": "string"
    }
  },
  "required": [
    "eventId",
    "eventName",
    "eventVersion",
    "aggregateType",
    "aggregateId",
    "occurredAt",
    "producer",
    "payload"
  ],
  "title": "report.generated v1",
  "type": "object"
}
