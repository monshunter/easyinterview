{
  "$id": "shared/events/schemas/resume.parse.completed.v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "aggregateId": {
      "format": "uuid",
      "type": "string"
    },
    "aggregateType": {
      "const": "resume"
    },
    "eventId": {
      "format": "uuid",
      "type": "string"
    },
    "eventName": {
      "const": "resume.parse.completed"
    },
    "eventVersion": {
      "const": 1
    },
    "occurredAt": {
      "format": "date-time",
      "type": "string"
    },
    "payload": {
      "additionalProperties": false,
      "properties": {
        "parseStatus": {
          "$ref": "../refs/TargetJobParseStatus.json"
        },
        "resumeId": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        }
      },
      "required": [
        "parseStatus",
        "resumeId",
        "userId"
      ],
      "type": "object"
    },
    "producer": {
      "enum": [
        "backend_async"
      ]
    },
    "traceId": {
      "type": "string"
    }
  },
  "required": [
    "eventId",
    "eventName",
    "eventVersion",
    "aggregateType",
    "aggregateId",
    "occurredAt",
    "producer",
    "payload"
  ],
  "title": "resume.parse.completed v1",
  "type": "object"
}
