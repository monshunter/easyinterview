# E2E.P0.100 full-funnel hybrid real-provider env template.
# Copy to .test-output/e2e/p0-100-real-provider-full-funnel-hybrid/dev-real.env and fill locally.
# Do not commit the copied file or real secrets.

APP_ENV=dev
APP_LISTEN_ADDR=:8080
DATABASE_URL=postgres://easyinterview:dev@localhost:5432/easyinterview?sslmode=disable
REDIS_URL=redis://localhost:6379/0
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=easyinterview-dev
OBJECT_STORAGE_ACCESS_KEY=dev-access-key
OBJECT_STORAGE_SECRET_KEY=dev-secret-key

# Required for backend auth runtime.
SESSION_COOKIE_SECRET=
AUTH_CHALLENGE_TOKEN_PEPPER=
EMAIL_PROVIDER=mailpit
EMAIL_SMTP_HOST=127.0.0.1
EMAIL_SMTP_PORT=1025
EMAIL_FROM_ADDRESS=noreply@easyinterview.local
EMAIL_VERIFY_BASE_URL=http://127.0.0.1:8080/api/v1/auth/email/verify
EMAIL_PROVIDER_API_KEY=

# Real AI provider. Current repo-tracked dev profiles use DeepSeek refs.
AI_PROVIDER_REGISTRY_PATH=config/ai-providers.yaml
AI_MODEL_PROFILE_PATH=config/ai-profiles.yaml
AI_PROVIDER_BASE_URL=https://api.deepseek.com
AI_PROVIDER_API_KEY=

FEATURE_FLAG_SOURCE=file
FEATURE_FLAG_FILE_PATH=config/feature-flags.yaml

# Frontend real-mode values.
VITE_EI_API_MODE=real
VITE_EI_API_BASE_URL=http://127.0.0.1:8080/api/v1
