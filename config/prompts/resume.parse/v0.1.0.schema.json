{
  "type": "object",
  "description": "Structured resume summary parsed from supplied resume text.",
  "required": [
    "displayName",
    "markdownText",
    "basics",
    "experiences",
    "projects",
    "education",
    "skills",
    "languages"
  ],
  "properties": {
    "displayName": {
      "type": "string",
      "description": "Short meaningful resume name for UI display, derived from candidate name plus headline, role, or strongest technical positioning; never use uploaded/pasted resume, the file name, or a raw first-line copy."
    },
    "markdownText": {
      "type": "string",
      "description": "Complete resume text converted to Markdown while preserving the source resume's writing order, section structure, wording, bullets, and factual content. Do not summarize, rewrite, add, remove, or reorder resume content."
    },
    "basics": {
      "type": "object",
      "description": "Basic candidate identity and contact summary.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Candidate name when present."
        },
        "headline": {
          "type": "string",
          "description": "Candidate headline or target positioning."
        },
        "contact": {
          "type": "string",
          "description": "Sanitized contact summary."
        }
      }
    },
    "experiences": {
      "type": "array",
      "description": "Work experience entries.",
      "items": {
        "type": "object",
        "description": "One work experience entry.",
        "properties": {
          "company": {
            "type": "string",
            "description": "Company name."
          },
          "title": {
            "type": "string",
            "description": "Role title."
          },
          "start": {
            "type": "string",
            "description": "Start date as stated or normalized."
          },
          "end": {
            "type": "string",
            "description": "End date as stated or normalized."
          },
          "summary": {
            "type": "string",
            "description": "Brief experience summary."
          },
          "bullets": {
            "type": "array",
            "description": "Resume bullets for this experience.",
            "items": {
              "type": "string",
              "description": "One bullet."
            }
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "description": "Project entries.",
      "items": {
        "type": "object",
        "description": "One project entry.",
        "properties": {
          "name": {
            "type": "string",
            "description": "Project name."
          },
          "summary": {
            "type": "string",
            "description": "Brief project summary."
          },
          "technologies": {
            "type": "array",
            "description": "Technologies or methods used in the project.",
            "items": {
              "type": "string",
              "description": "One technology or method."
            }
          },
          "bullets": {
            "type": "array",
            "description": "Project bullets or impact notes.",
            "items": {
              "type": "string",
              "description": "One project bullet."
            }
          }
        }
      }
    },
    "education": {
      "type": "array",
      "description": "Education entries.",
      "items": {
        "type": "object",
        "description": "One education entry.",
        "properties": {
          "school": {
            "type": "string",
            "description": "School or institution name."
          },
          "degree": {
            "type": "string",
            "description": "Degree or credential."
          },
          "field": {
            "type": "string",
            "description": "Field of study when present."
          },
          "start": {
            "type": "string",
            "description": "Start date as stated or normalized."
          },
          "end": {
            "type": "string",
            "description": "End date as stated or normalized."
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "description": "Skill keywords.",
      "items": {
        "type": "string",
        "description": "One skill."
      }
    },
    "languages": {
      "type": "array",
      "description": "Language proficiencies.",
      "items": {
        "type": "string",
        "description": "One language."
      }
    }
  }
}
