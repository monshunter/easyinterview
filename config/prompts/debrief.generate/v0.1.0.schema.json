{
  "type": "object",
  "description": "Completed real-interview debrief analysis.",
  "required": [
    "questions",
    "riskItems"
  ],
  "properties": {
    "questions": {
      "type": "array",
      "description": "Analyzed debrief questions preserving input order.",
      "items": {
        "type": "object",
        "description": "One analyzed interview question.",
        "required": [
          "questionText",
          "myAnswerSummary",
          "aiAnalysis"
        ],
        "properties": {
          "questionText": {
            "type": "string",
            "description": "Original or cleaned interview question text."
          },
          "myAnswerSummary": {
            "type": "string",
            "description": "Candidate answer summary."
          },
          "interviewerReaction": {
            "type": "string",
            "description": "Interviewer reaction when supplied by the candidate."
          },
          "aiAnalysis": {
            "type": "string",
            "description": "Concise coaching analysis."
          }
        }
      }
    },
    "riskItems": {
      "type": "array",
      "description": "Risks or follow-up concerns from the debrief.",
      "items": {
        "type": "object",
        "description": "One risk item.",
        "required": [
          "label",
          "severity"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Risk label."
          },
          "severity": {
            "type": "string",
            "description": "Risk severity.",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    }
  }
}
