{
  "type": "object",
  "description": "Impact-driven resume bullet rewrite suggestions.",
  "required": [
    "suggestions"
  ],
  "properties": {
    "suggestions": {
      "type": "array",
      "description": "Canonical bullet suggestions persisted for review.",
      "minItems": 1,
      "items": {
        "type": "object",
        "description": "One bullet suggestion.",
        "required": [
          "originalBullet",
          "suggestedBullet",
          "reason"
        ],
        "properties": {
          "originalBullet": {
            "type": "string",
            "description": "Original source bullet for traceability.",
            "minLength": 1,
            "pattern": ".*\\S.*"
          },
          "suggestedBullet": {
            "type": "string",
            "description": "Truthful rewritten bullet tailored to the target JD.",
            "minLength": 1,
            "pattern": ".*\\S.*"
          },
          "reason": {
            "type": "string",
            "description": "Why the suggested bullet is stronger."
          }
        }
      }
    }
  }
}
