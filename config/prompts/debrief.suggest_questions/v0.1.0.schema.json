{
  "type": "object",
  "description": "Likely post-interview debrief questions.",
  "required": [
    "suggestions"
  ],
  "properties": {
    "suggestions": {
      "type": "array",
      "description": "Suggested questions the candidate can answer from memory.",
      "items": {
        "type": "object",
        "description": "One suggested debrief question.",
        "required": [
          "questionText",
          "whyLikelyAsked",
          "source"
        ],
        "properties": {
          "questionText": {
            "type": "string",
            "description": "Likely interview question."
          },
          "whyLikelyAsked": {
            "type": "string",
            "description": "Why this question is likely or useful."
          },
          "source": {
            "type": "string",
            "description": "Context source that motivated the question.",
            "enum": [
              "jd",
              "resume",
              "mock_report",
              "manual"
            ]
          },
          "stage": {
            "type": "string",
            "description": "Optional interview stage or topic grouping."
          }
        }
      }
    }
  }
}
