{
  "type": "object",
  "description": "Per-question rubric assessment.",
  "required": [
    "dimension_results",
    "overall_status",
    "confidence",
    "strengths",
    "gaps",
    "recommended_framework",
    "review_status"
  ],
  "properties": {
    "dimension_results": {
      "type": "object",
      "description": "Map keyed by rubric dimension name. Each value contains score_level, status, confidence, and optional score."
    },
    "overall_status": {
      "type": "string",
      "description": "Overall dimension status.",
      "enum": [
        "needs_work",
        "meets_bar",
        "strong"
      ]
    },
    "confidence": {
      "type": "number",
      "description": "Overall confidence score."
    },
    "strengths": {
      "type": "array",
      "description": "Strength observations for this answer.",
      "items": {
        "type": "string",
        "description": "One strength."
      }
    },
    "gaps": {
      "type": "array",
      "description": "Gap observations for this answer.",
      "items": {
        "type": "string",
        "description": "One gap."
      }
    },
    "recommended_framework": {
      "type": "string",
      "description": "Suggested answer framework for retry."
    },
    "review_status": {
      "type": "string",
      "description": "Question review status.",
      "enum": [
        "open",
        "queued_for_retry",
        "resolved"
      ]
    }
  }
}
