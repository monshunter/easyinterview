# easyinterview local dev stack — environment overrides.
#
# Copy to deploy/dev-stack/.env and edit as needed; .env is gitignored.
# `make dev-up` auto-copies this file to .env on first run if .env is absent.
# Field names follow docs/spec/secrets-and-config/spec.md §3.1.1 P0 env dict.
# Real AI provider credentials must NEVER be committed; the values below are
# placeholders and intentionally empty for AI_PROVIDER_API_KEY.

# -- Application runtime (consumed by backend/frontend child plans) --
APP_ENV=dev
APP_LISTEN_ADDR=:8080
LOG_LEVEL=info

# -- Postgres (A2 owns local defaults) --
POSTGRES_USER=easyinterview
POSTGRES_PASSWORD=dev
POSTGRES_DB=easyinterview
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://easyinterview:dev@localhost:5432/easyinterview?sslmode=disable

# -- Redis --
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379/0

# -- MinIO / object storage --
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=easyinterview-dev
OBJECT_STORAGE_ACCESS_KEY=dev-access-key
OBJECT_STORAGE_SECRET_KEY=dev-secret-key

# -- Project component host ports (added when child plans land runtime entries) --
API_HOST_PORT=8080
FRONTEND_HOST_PORT=5173

# -- AI provider (real provider required for local docker compose & Kind) --
# Point AI_PROVIDER_BASE_URL at the provider selected by config/ai-profiles.yaml.
# Components with AIClient enabled fail-fast if required registry/profile paths
# or selected provider secrets are missing in non-test environments.
AI_PROVIDER_REGISTRY_PATH=config/ai-providers.yaml
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY=
AI_MODEL_PROFILE_PATH=config/ai-profiles.yaml

# -- Feature flags --
FEATURE_FLAG_SOURCE=file
FEATURE_FLAG_FILE_PATH=config/feature-flags.yaml
