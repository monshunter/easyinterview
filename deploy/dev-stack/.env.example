# easyinterview local dev stack — environment overrides.
#
# Copy to deploy/dev-stack/.env and edit as needed; .env is gitignored.
# `make dev-up` auto-copies this file to .env on first run if .env is absent.
# Field names follow docs/spec/secrets-and-config/spec.md §3.1.1 P0 env dict.
# Real AI provider credentials must NEVER be committed; the values below are
# placeholders and intentionally empty for AI_PROVIDER_API_KEY.

# -- Application runtime (consumed by backend/frontend child plans) --
APP_ENV=dev
APP_LISTEN_ADDR=:10901
LOG_LEVEL=info
SESSION_COOKIE_SECRET=
AUTH_CHALLENGE_TOKEN_PEPPER=

# -- Postgres (A2 owns local defaults) --
POSTGRES_USER=easyinterview
POSTGRES_PASSWORD=dev
POSTGRES_DB=easyinterview
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgres://easyinterview:dev@localhost:5432/easyinterview?sslmode=disable

# -- Redis --
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379/0

# -- MinIO / object storage --
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=easyinterview-dev
OBJECT_STORAGE_ACCESS_KEY=dev-access-key
OBJECT_STORAGE_SECRET_KEY=dev-secret-key

# -- Mailpit / local email sink --
MAILPIT_WEB_HOST_PORT=8025
MAILPIT_SMTP_HOST_PORT=1025
EMAIL_PROVIDER=mailpit
EMAIL_SMTP_HOST=127.0.0.1
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_TLS_MODE=none
EMAIL_FROM_ADDRESS=noreply@easyinterview.local
# Kept for local frontend-origin/CORS derivation; email body is code-only.
EMAIL_VERIFY_BASE_URL=http://127.0.0.1:10900/auth/verify

# -- Project component host ports (added when child plans land runtime entries) --
API_HOST_PORT=10901
FRONTEND_HOST_PORT=10900
FRONTEND_PREVIEW_PORT=4173
FULL_CONTAINER_FRONTEND_HOST_PORT=10900
FULL_CONTAINER_API_HOST_PORT=10901
VITE_EI_API_MODE=real
VITE_EI_API_BASE_URL=http://127.0.0.1:10901/api/v1

# -- AI provider (real provider required for non-test local app runs and deploys) --
# Current dev profiles select DeepSeek V4 Flash/Pro through provider ref `deepseek`.
# Components with AIClient enabled fail-fast if required registry/profile paths
# or selected provider secrets are missing in non-test environments.
AI_PROVIDER_REGISTRY_PATH=config/ai-providers.yaml
AI_PROVIDER_BASE_URL=https://api.deepseek.com
AI_PROVIDER_API_KEY=
AI_MODEL_PROFILE_PATH=config/ai-profiles.yaml
# Dedicated local-only AIClient.Complete request/response capture. The path is
# resolved from the parent of ConfigDir (the repository root for host runs).
AI_DEBUG_CAPTURE_RAW_IO=true
AI_DEBUG_RAW_IO_PATH=.test-output/local-dev/ai-raw.ndjson

# -- Feature flags --
FEATURE_FLAG_SOURCE=file
FEATURE_FLAG_FILE_PATH=config/feature-flags.yaml
