# syntax=docker/dockerfile:1

FROM node:22.14.0-alpine AS builder

RUN corepack enable && corepack prepare pnpm@10.4.0 --activate
WORKDIR /src

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY frontend/package.json frontend/package.json
RUN --mount=type=cache,target=/pnpm/store \
    pnpm config set store-dir /pnpm/store \
    && pnpm --dir frontend install \
    --ignore-workspace \
    --frozen-lockfile \
    --lockfile-dir /src

COPY frontend/ frontend/
COPY openapi/fixtures/ openapi/fixtures/
COPY shared/fixtures/ shared/fixtures/
ARG VITE_EI_API_MODE=real
ARG VITE_EI_API_BASE_URL=/api/v1
ENV VITE_EI_API_MODE=${VITE_EI_API_MODE}
ENV VITE_EI_API_BASE_URL=${VITE_EI_API_BASE_URL}
RUN pnpm --filter @easyinterview/frontend build

FROM nginx:1.27-alpine

COPY deploy/dev-stack/frontend-nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /src/frontend/dist/ /usr/share/nginx/html/

EXPOSE 8080
HEALTHCHECK --interval=5s --timeout=3s --retries=5 \
  CMD wget -q --spider http://127.0.0.1:8080/ || exit 1
